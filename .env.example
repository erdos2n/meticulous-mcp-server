# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Local IP of your Meticulous machine (find it in your router or machine settings)
METICULOUS_IP=192.168.x.x

# Bearer token for the HTTP entry point (Pi / Cloudflare Tunnel / Claude mobile).
# Generate a new token with: npm run generate-token
# Paste the same token into your claude.ai connector config.
MCP_AUTH_TOKEN=your-token-here

# Port for the HTTP server (default: 3000)
# PORT=3000
