{
  "name": "meticulous-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Meticulous home espresso machine — recipe generation, shot history, and machine control for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meticulous-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/http.ts --format esm --sourcemap",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "node dist/http.js",
    "generate-token": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
  },
  "dependencies": {
    "@meticulous-home/espresso-api": "^0.10.8",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.33",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
