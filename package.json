{
  "name": "meticulous-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Meticulous home espresso machine — recipe generation, shot history, and machine control for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meticulous-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@meticulous-home/espresso-api": "^0.10.8",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
